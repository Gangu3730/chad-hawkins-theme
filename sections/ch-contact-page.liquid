{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  
  <div class="chp-container chp-section-spacing">
    
    <!-- Header -->
    <div class="chp-section-header chp-reveal">
      <span class="chp-section-sub">{{ section.settings.subheading | escape }}</span>
      <h1 class="chp-section-title chp-serif">{{ section.settings.title | escape }}</h1>
      
      <div class="chp-divider">
        <div class="chp-divider-line"></div>
        <div class="chp-divider-flourish">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="3" fill="none"/>
          </svg>
        </div>
        <div class="chp-divider-line"></div>
      </div>
      
      {%- if section.settings.subtitle != blank -%}
        <p class="chp-section-desc">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>

    <!-- Contact Grid -->
    <div class="chp-contact-grid">
      
      <!-- Info Col -->
      <div class="chp-contact-info-col chp-reveal">
        {%- if section.settings.intro_text != blank -%}
          <p style="color: var(--ch-text); font-size: 1rem; line-height: 1.7; margin: 0 0 35px 0;">
            {{ section.settings.intro_text | escape }}
          </p>
        {%- endif -%}

        <!-- Location -->
        <div class="chp-contact-detail-row">
          <div class="chp-contact-detail-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <span class="chp-contact-detail-label">{{ section.settings.location_label | escape }}</span>
            <span class="chp-contact-detail-val">{{ section.settings.location_value | escape }}</span>
          </div>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--ch-border); margin: 30px 0;">

        <!-- Socials -->
        <span class="chp-contact-detail-label" style="margin-bottom: 12px;">{{ section.settings.follow_label | escape }}</span>
        <div style="display: flex; gap: 12px;">
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="chp-filter-btn" style="padding: 8px 16px;" target="_blank">Facebook</a>
          {%- endif -%}
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="chp-filter-btn" style="padding: 8px 16px;" target="_blank">Instagram</a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="chp-filter-btn" style="padding: 8px 16px;" target="_blank">Pinterest</a>
          {%- endif -%}
        </div>
      </div>

      <!-- Form Col -->
      <div class="chp-contact-form-wrap chp-reveal">
        {%- form 'contact', id: 'ChpContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="chp-form-message chp-form-message-success">
              Thanks for contacting us. We will get back to you as soon as possible.
            </div>
          {%- elsif form.errors -%}
            <div class="chp-form-message chp-form-message-error">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="chp-form-row">
            <div class="chp-form-group">
              <label for="ChpContactForm-name">Name</label>
              <input
                type="text"
                name="contact[name]"
                id="ChpContactForm-name"
                class="chp-form-control"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                placeholder="Your Name"
                required
              >
            </div>

            <div class="chp-form-group">
              <label for="ChpContactForm-email">Email Address</label>
              <input
                type="email"
                name="contact[email]"
                id="ChpContactForm-email"
                class="chp-form-control"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                placeholder="Your Email"
                required
              >
            </div>
          </div>

          <div class="chp-form-group">
            <label for="ChpContactForm-subject">Subject</label>
            <input
              type="text"
              name="contact[subject]"
              id="ChpContactForm-subject"
              class="chp-form-control"
              placeholder="Subject of Inquiry"
              required
            >
          </div>

          <div class="chp-form-group">
            <label for="ChpContactForm-message">Message</label>
            <textarea
              name="contact[body]"
              id="ChpContactForm-message"
              class="chp-form-control"
              rows="6"
              placeholder="Tell us about your portrait tribute needs..."
              required
            >{%- if form.body -%}{{ form.body }}{%- endif -%}</textarea>
          </div>

          <button type="submit" class="chp-btn chp-btn-navy" style="width: 100%;">
            {{ section.settings.btn_text | default: 'SEND MESSAGE' | escape }}
          </button>

          {%- if section.settings.show_privacy_banner -%}
            <p style="font-size: 0.75rem; color: var(--ch-muted); text-align: center; margin-top: 15px; margin-bottom: 0;">
              🛡️ {{ section.settings.privacy_text | escape }}
            </p>
          {%- endif -%}

        {%- endform -%}
      </div>

    </div>

  </div>

</div>

{% schema %}
{
  "name": "Contact Page Section",
  "tag": "section",
  "class": "ch-contact-page-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "CONTACT"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "GET IN TOUCH"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We'd love to hear from you."
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Introductory Copy",
      "default": "Questions about portraits? Ideas for a tribute video? Or simply want to say hello? Get in touch with us using the form or the info below."
    },
    {
      "type": "text",
      "id": "location_label",
      "label": "Location Label",
      "default": "LOCATION"
    },
    {
      "type": "text",
      "id": "location_value",
      "label": "Location Value",
      "default": "Salt Lake City, Utah"
    },
    {
      "type": "text",
      "id": "follow_label",
      "label": "Follow Socials Label",
      "default": "FOLLOW"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook Page URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram Profile URL"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "Pinterest Profile URL"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Submit Button Label",
      "default": "SEND MESSAGE"
    },
    {
      "type": "checkbox",
      "id": "show_privacy_banner",
      "label": "Show Privacy Lock Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy text",
      "default": "Your information is safe with us. We respect your privacy."
    }
  ],
  "presets": [
    {
      "name": "Contact Page Section"
    }
  ]
}
{% endschema %}
