{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper" id="chp-hero">
  <header class="chp-hero" style="background-image: url({% if section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 1800 }}{% else %}''{% endif %});">
    <div class="chp-hero-overlay"></div>
    <div class="chp-container" style="position: relative; z-index: 2; width: 100%;">
      <div style="display: grid; grid-template-columns: 1fr; gap: 40px; align-items: center;" class="chp-hero-grid-wrapper">
        <div class="chp-hero-content ch-reveal-group">
          {%- if section.settings.hero_subheading != blank -%}
            <span class="chp-hero-sub ch-reveal ch-reveal-item" style="display: inline-block;">{{ section.settings.hero_subheading | escape }}</span>
          {%- endif -%}
          {%- if section.settings.hero_heading != blank -%}
            <h1 class="chp-hero-title ch-text-reveal-kinetic">{{ section.settings.hero_heading | escape }}</h1>
          {%- endif -%}
          {%- if section.settings.hero_text != blank -%}
            <p class="chp-hero-text ch-reveal ch-reveal-item">{{ section.settings.hero_text | escape }}</p>
          {%- endif -%}
          
          <div style="display: flex; flex-wrap: wrap; gap: 16px;" class="ch-reveal ch-reveal-item">
            {%- if section.settings.hero_btn_1_text != blank -%}
              <a href="{{ section.settings.hero_btn_1_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
                {{ section.settings.hero_btn_1_text | escape }}
              </a>
            {%- endif -%}
            {%- if section.settings.hero_btn_2_text != blank -%}
              <a href="{{ section.settings.hero_btn_2_link | default: '#' }}" class="chp-btn chp-btn-outline-white">
                {{ section.settings.hero_btn_2_text | escape }}
              </a>
            {%- endif -%}
          </div>

          <ul class="chp-hero-proof-list ch-reveal ch-reveal-item" aria-label="Commission highlights">
            <li>Original hand-drawn artwork</li>
            <li>Created from your photos</li>
            <li>Proof review before final detail</li>
            <li>Shipped safely with archive files</li>
          </ul>
        </div>

        <!-- Overlap Image Area -->
        <div class="chp-hero-media-wrapper" style="position: relative; display: flex; justify-content: flex-end;">
          <div class="chp-hero-image-frame ch-reveal" style="position: relative; border: 1px solid rgba(255,255,255,0.2); padding: 12px; background: rgba(255,255,255,0.05); backdrop-filter: blur(5px); max-width: 500px; width: 100%;">
            {%- if section.settings.hero_art_image != blank -%}
              <img src="{{ section.settings.hero_art_image | image_url: width: 800 }}" alt="{{ section.settings.hero_art_image.alt | escape }}" width="{{ section.settings.hero_art_image.width }}" height="{{ section.settings.hero_art_image.height }}" style="width: 100%; height: auto; display: block;" loading="eager" />
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <!-- Navy Overlapping Badge -->
            {%- if section.settings.badge_title != blank or section.settings.badge_text != blank -%}
              <div class="chp-hero-badge ch-reveal" style="position: absolute; bottom: -20px; left: -20px; background-color: var(--ch-navy); color: var(--ch-white); padding: 24px; border: 1px solid var(--ch-border); max-width: 240px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); transition-delay: 0.4s;">
                <h4 class="chp-serif" style="font-size: 1.1rem; text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 0.05em; color: var(--ch-white);">
                  {{ section.settings.badge_title | escape }}
                </h4>
                <p class="chp-sans" style="font-size: 0.8125rem; margin: 0; opacity: 0.8; line-height: 1.4;">
                  {{ section.settings.badge_text | escape }}
                </p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </header>
</div>
{% schema %}
{
  "name": "Premium Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_bg_image",
      "label": "Hero Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_art_image",
      "label": "Hero Showcase Artwork"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "Hero Subheading",
      "default": "COMMISSION A HAND-DRAWN PORTRAIT"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Custom Pencil Sketches That Preserve Life's Most Meaningful Moments"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero Subtext",
      "default": "Commission a hand-drawn portrait, memorial sketch, or tribute artwork created from your favorite photographs with careful detail and a timeless finish."
    },
    {
      "type": "text",
      "id": "hero_btn_1_text",
      "label": "Primary Button Text",
      "default": "Book Your Tribute"
    },
    {
      "type": "url",
      "id": "hero_btn_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "hero_btn_2_text",
      "label": "Secondary Button Text",
      "default": "View Portfolio"
    },
    {
      "type": "url",
      "id": "hero_btn_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Overlap Badge Title",
      "default": "Original Pencil Art"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Overlap Badge Text",
      "default": "Photo-guided commissions, hand drawn by Chad Hawkins."
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Banner"
    }
  ]
}
{% endschema %}
