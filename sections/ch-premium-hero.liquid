{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper" id="chp-hero">
  <section class="ch-hero-2026">
    <!-- Full-bleed background image with ken-burns zoom -->
    <div class="ch-hero-bg">
      {%- if section.settings.hero_bg_image != blank -%}
        <img
          src="{{ section.settings.hero_bg_image | image_url: width: 1920 }}"
          alt="{{ section.settings.hero_bg_image.alt | escape }}"
          width="{{ section.settings.hero_bg_image.width }}"
          height="{{ section.settings.hero_bg_image.height }}"
          class="ch-hero-bg-img"
          loading="eager"
          fetchpriority="high"
        />
      {%- endif -%}
      <div class="ch-hero-bg-overlay"></div>
    </div>

    <div class="ch-hero-inner">
      <!-- Left: Text content -->
      <div class="ch-hero-text-col ch-reveal-group">
        {%- if section.settings.hero_subheading != blank -%}
          <div class="ch-hero-eyebrow ch-reveal-item">
            <span class="ch-hero-eyebrow-line"></span>
            <span class="ch-hero-eyebrow-text">{{ section.settings.hero_subheading | escape }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.hero_heading != blank -%}
          <h1 class="ch-hero-headline ch-text-reveal-kinetic">{{ section.settings.hero_heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.hero_text != blank -%}
          <p class="ch-hero-body ch-reveal-item">{{ section.settings.hero_text | escape }}</p>
        {%- endif -%}

        <div class="ch-hero-actions ch-reveal-item">
          {%- if section.settings.hero_btn_1_text != blank -%}
            <a href="{{ section.settings.hero_btn_1_link | default: '#' }}" class="ch-hero-btn ch-hero-btn--primary">
              <span>{{ section.settings.hero_btn_1_text | escape }}</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.hero_btn_2_text != blank -%}
            <a href="{{ section.settings.hero_btn_2_link | default: '#' }}" class="ch-hero-btn ch-hero-btn--ghost">
              {{ section.settings.hero_btn_2_text | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Right: Showcase artwork with frame -->
      <div class="ch-hero-art-col">
        <div class="ch-hero-art-frame ch-mask-reveal-up">
          {%- if section.settings.hero_art_image != blank -%}
            <img
              src="{{ section.settings.hero_art_image | image_url: width: 900 }}"
              alt="{{ section.settings.hero_art_image.alt | escape }}"
              width="{{ section.settings.hero_art_image.width }}"
              height="{{ section.settings.hero_art_image.height }}"
              class="ch-hero-art-img"
              loading="eager"
            />
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg ch-hero-art-img' }}
          {%- endif -%}

          <!-- Badge floats inside art -->
          {%- if section.settings.badge_title != blank or section.settings.badge_text != blank -%}
            <div class="ch-hero-art-badge ch-reveal" style="transition-delay: 1s;">
              <h4>{{ section.settings.badge_title | escape }}</h4>
              <p>{{ section.settings.badge_text | escape }}</p>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="ch-hero-scroll-hint ch-reveal" style="transition-delay: 1.6s;">
      <span class="ch-scroll-line"></span>
      <span class="ch-scroll-label">Scroll</span>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Premium Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_bg_image",
      "label": "Hero Background Image"
    },
    {
      "type": "image_picker",
      "id": "hero_art_image",
      "label": "Hero Showcase Artwork"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "Hero Subheading",
      "default": "COMMISSION A HAND-DRAWN PORTRAIT"
    },
    {
      "type": "text",
      "id": "hero_heading",
      "label": "Hero Heading",
      "default": "Hand Drawn Tributes That Preserve Life's Most Meaningful Moments"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero Subtext",
      "default": "Custom hand-drawn portraits and tribute videos created with care, emotion, and timeless attention to detail."
    },
    {
      "type": "text",
      "id": "hero_btn_1_text",
      "label": "Primary Button Text",
      "default": "Book Your Tribute"
    },
    {
      "type": "url",
      "id": "hero_btn_1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "hero_btn_2_text",
      "label": "Secondary Button Text",
      "default": "View Portfolio"
    },
    {
      "type": "url",
      "id": "hero_btn_2_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Overlap Badge Title",
      "default": "Hand-Drawn Tributes"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Overlap Badge Text",
      "default": "Timeless pencil & ink commissions by Chad Hawkins."
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Banner"
    }
  ]
}
{% endschema %}
