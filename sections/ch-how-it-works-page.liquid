{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  
  <div class="chp-container chp-section-spacing chp-timeline-section">
    <!-- Header -->
    <div class="chp-section-header chp-reveal">
      <span class="chp-section-sub">{{ section.settings.subtitle | escape }}</span>
      <h1 class="chp-section-title chp-serif">{{ section.settings.title | escape }}</h1>
      
      <div class="chp-divider">
        <div class="chp-divider-line"></div>
        <div class="chp-divider-flourish">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="3" fill="none"/>
          </svg>
        </div>
        <div class="chp-divider-line"></div>
      </div>
      
      {%- if section.settings.description != blank -%}
        <p class="chp-section-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    <!-- Timeline Wrapper -->
    <div class="chp-timeline-wrap">
      <div class="chp-timeline-line">
        <div class="chp-timeline-fill"></div>
      </div>

      {%- assign step_index = 1 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'timeline_step' -%}
          <div class="chp-timeline-item chp-reveal" {{ block.shopify_attributes }}>
            <div class="chp-timeline-node"></div>
            <div class="chp-timeline-content">
              <span class="chp-timeline-step">Step 0{{ step_index }}</span>
              <h3 class="chp-serif" style="color: var(--ch-navy); margin: 0 0 10px 0; font-size: 1.35rem; font-weight: 500;">
                {{ block.settings.title | escape }}
              </h3>
              <p class="chp-sans" style="font-size: 0.9375rem; color: var(--ch-muted); line-height: 1.6; margin: 0;">
                {{ block.settings.description | escape }}
              </p>
            </div>
          </div>
          {%- assign step_index = step_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- Booking CTA Block -->
    {%- if section.settings.show_cta -%}
      <div class="chp-timeline-cta chp-reveal" style="background-color: var(--ch-navy); color: var(--ch-white); padding: 50px 40px; text-align: center; border: 1px solid var(--ch-border); margin-top: 80px; box-shadow: 0 10px 30px rgba(6, 43, 85, 0.05); position: relative; overflow: hidden;">
        <h2 class="chp-serif" style="font-size: 1.75rem; color: var(--ch-white); margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 0.05em;">
          {{ section.settings.cta_title | escape }}
        </h2>
        <p class="chp-sans" style="font-size: 0.9375rem; opacity: 0.8; max-width: 600px; margin: 0 auto 30px auto; line-height: 1.6;">
          {{ section.settings.cta_text | escape }}
        </p>
        <a href="{{ section.settings.cta_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
          {{ section.settings.cta_btn_label | default: 'Book Your Tribute Now' | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>

</div>

{% schema %}
{
  "name": "How It Works Page",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "THE COMMISSION SYSTEM"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "A Simple, Thoughtful Experience"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We make the process of commissioning a custom hand-drawn portrait simple, transparent, and meaningful."
    },
    {
      "type": "header",
      "content": "CTA Settings"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Strip",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Heading",
      "default": "LET'S CREATE A TRIBUTE PORTRAIT TOGETHER."
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Begin your legacy piece today by choosing a package and sharing your story."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "START YOUR COMMISSION"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "timeline_step",
      "name": "Timeline Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Choose Your Tribute"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Select the style, format, and size that fits the tribute you want to create."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works Timeline"
    }
  ]
}
{% endschema %}
