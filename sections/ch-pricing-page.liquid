{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Accordion toggle helper
    document.querySelectorAll('.chp-faq-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.parentElement;
        const content = item.querySelector('.chp-faq-content');
        const icon = trigger.querySelector('.chp-faq-icon');
        const isOpen = item.classList.toggle('is-open');
        
        if (isOpen) {
          content.style.maxHeight = content.scrollHeight + 'px';
          icon.style.transform = 'rotate(45deg)';
        } else {
          content.style.maxHeight = '0px';
          icon.style.transform = 'rotate(0deg)';
        }
      });
    });
  });
</script>

<div class="chp chp-wrapper">
  
  <!-- Hero Section -->
  <div class="chp-container chp-section-spacing">
    <div class="chp-section-header chp-reveal">
      <span class="chp-section-sub">{{ section.settings.subheading | escape }}</span>
      <h1 class="chp-section-title chp-serif">{{ section.settings.title | escape }}</h1>
      
      <div class="chp-divider">
        <div class="chp-divider-line"></div>
        <div class="chp-divider-flourish">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="3" fill="none"/>
          </svg>
        </div>
        <div class="chp-divider-line"></div>
      </div>
      
      {%- if section.settings.description != blank -%}
        <p class="chp-section-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    <!-- Pricing Grid -->
    <div class="chp-packages-grid chp-stagger" style="margin-bottom: 100px;">
      {%- for block in section.blocks -%}
        {%- if block.type == 'package' -%}
          <div class="chp-package-card {% if block.settings.featured %}is-featured{% endif %} chp-stagger-item" {{ block.shopify_attributes }}>
            {%- if block.settings.badge != blank -%}
              <span class="chp-package-badge">{{ block.settings.badge | escape }}</span>
            {%- endif -%}
            
            <h3 class="chp-package-title">{{ block.settings.name | escape }}</h3>
            
            <div class="chp-package-price-wrap">
              <span class="chp-package-price">{{ block.settings.price | escape }}</span>
              <span class="chp-package-price-sub">/ One-time fee</span>
            </div>
            
            <ul class="chp-package-features">
              {%- assign lines = block.settings.features | split: ',' -%}
              {%- for line in lines -%}
                {%- assign clean_line = line | strip -%}
                {%- if clean_line != blank -%}
                  <li class="chp-package-feature-item">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {{ clean_line | escape }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
            
            <a href="{{ block.settings.btn_link | default: '#' }}" class="chp-btn {% if block.settings.featured %}chp-btn-navy{% else %}chp-btn-outline-navy{% endif %}" style="width: 100%;">
              {{ block.settings.btn_label | escape }}
            </a>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- FAQ Accordion Block -->
    <div class="chp-section-header chp-reveal" style="margin-top: 80px; margin-bottom: 40px;">
      <span class="chp-section-sub">FAQ</span>
      <h2 class="chp-section-title chp-serif">Frequently Asked Questions</h2>
    </div>

    <div class="chp-faq-wrapper chp-reveal">
      {%- for block in section.blocks -%}
        {%- if block.type == 'faq_item' -%}
          <div class="chp-faq-item" {{ block.shopify_attributes }}>
            <button class="chp-faq-trigger">
              <span class="chp-faq-question chp-serif">{{ block.settings.question | escape }}</span>
              <span class="chp-faq-icon">+</span>
            </button>
            <div class="chp-faq-content">
              <div class="chp-faq-answer chp-sans">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  <!-- CTA section -->
  {%- if section.settings.show_cta -%}
    <section class="chp-section-spacing chp-navy-cta">
      <div class="chp-container">
        <div class="chp-navy-cta-inner chp-reveal">
          <h2>{{ section.settings.cta_title | escape }}</h2>
          <p>{{ section.settings.cta_text | escape }}</p>
          {%- if section.settings.cta_btn_label != blank and section.settings.cta_btn_link != blank -%}
            <a href="{{ section.settings.cta_btn_link }}" class="chp-btn chp-btn-solid-white">
              {{ section.settings.cta_btn_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Pricing Page Section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "PRICING & PACKAGES"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Commission Pricing"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "All pricing includes hand-drawn pencil/ink craftsmanship and lifetime legacy protection."
    },
    {
      "type": "header",
      "content": "CTA Settings"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Strip",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Heading",
      "default": "Looking for a custom size or specific layout?"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Contact us directly to discuss custom requirements and large-scale projects."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "GET IN TOUCH"
    },
    {
      "type": "url",
      "id": "cta_btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "package",
      "name": "Package Card",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Package Name",
          "default": "Portrait Tribute"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$450"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Card Badge (e.g. Popular)"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Features (separated by commas)",
          "default": "Hand-drawn portrait, High-resolution scan, Certificate of authenticity, Timeless premium display frame"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Order Commission"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Feature this package",
          "default": false
        }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does a portrait commission take?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Typically commissions are completed and shipped within 3 to 4 weeks. If you require a rush order, please get in touch."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pricing Page Section"
    }
  ]
}
{% endschema %}
