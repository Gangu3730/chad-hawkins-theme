{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper chp-section-spacing" style="min-height: 50vh; background-color: var(--ch-cream);">
  <div class="chp-container">
    <div class="chp-section-header">
      <span class="chp-section-subtitle">Your Curation</span>
      <h1 class="chp-section-title">My Wishlist</h1>
      <div class="chp-flourish">
        <div class="chp-flourish-line"></div>
        <div class="chp-flourish-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </div>
        <div class="chp-flourish-line"></div>
      </div>
    </div>

    <!-- Wishlist Grid -->
    <div id="chp-wishlist-grid" class="product-grid" style="display: none; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
      <!-- Wishlist items will be rendered here dynamically -->
    </div>

    <!-- Empty State -->
    <div id="chp-wishlist-empty" style="display: none; text-align: center; padding: 60px 20px;">
      <p class="chp-sans" style="font-size: 1.125rem; color: var(--ch-muted); margin-bottom: 30px;">
        Your wishlist is currently empty. Start exploring our hand-drawn tribute collections.
      </p>
      <a href="/collections/all" class="chp-btn chp-btn-navy">
        Explore Artworks
      </a>
    </div>

    <!-- Loading State -->
    <div id="chp-wishlist-loading" style="text-align: center; padding: 40px 0;">
      <p class="chp-sans" style="font-size: 1rem; color: var(--ch-muted);">Loading your wishlist...</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const grid = document.getElementById('chp-wishlist-grid');
    const emptyState = document.getElementById('chp-wishlist-empty');
    const loadingState = document.getElementById('chp-wishlist-loading');

    function renderWishlist() {
      // Access storage via exposed global API
      const wishlist = window.CH_Wishlist ? window.CH_Wishlist.get() : [];

      if (!wishlist || wishlist.length === 0) {
        if (loadingState) loadingState.style.display = 'none';
        if (grid) grid.style.display = 'none';
        if (emptyState) emptyState.style.display = 'block';
        return;
      }

      if (loadingState) loadingState.style.display = 'block';
      if (grid) {
        grid.innerHTML = '';
        grid.style.display = 'grid';
      }
      if (emptyState) emptyState.style.display = 'none';

      let loadedProducts = 0;
      let succeededProducts = 0;

      wishlist.forEach(handle => {
        fetch(`/products/${handle}.js`)
          .then(res => {
            if (!res.ok) throw new Error('Product not found');
            return res.json();
          })
          .then(product => {
            succeededProducts++;
            const priceFormatted = '$' + (product.price / 100).toLocaleString(undefined, {
              minimumFractionDigits: 2,
              maximumFractionDigits: 2
            });

            const card = document.createElement('div');
            card.className = 'product-card';
            card.style.position = 'relative';
            card.innerHTML = `
              <div class="product-card__gallery" style="position: relative; overflow: hidden;">
                <a href="${product.url}">
                  <img src="${product.featured_image}" alt="${product.title}" loading="lazy" style="width: 100%; height: auto; aspect-ratio: 1; object-fit: cover; display: block;">
                </a>
                <button type="button" class="chp-wishlist-remove-page-btn" data-handle="${product.handle}" aria-label="Remove item" style="position: absolute; top: 15px; right: 15px; width: 32px; height: 32px; border-radius: 50%; background: var(--ch-white); border: 1px solid var(--ch-border); display: flex; align-items: center; justify-content: center; font-size: 20px; line-height: 1; cursor: pointer; color: var(--ch-navy); box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 10; transition: all 0.3s ease;">
                  &times;
                </button>
              </div>
              <div class="product-card__content" style="padding-top: 15px; text-align: left;">
                <a href="${product.url}" class="product-card__title chp-serif" style="font-size: 1.125rem; color: var(--ch-navy); text-decoration: none; display: block; margin-bottom: 5px;">
                  ${product.title}
                </a>
                <div class="product-card__price chp-sans" style="font-size: 0.9375rem; color: var(--ch-muted); font-weight: 500;">
                  ${priceFormatted}
                </div>
              </div>
            `;
            grid.appendChild(card);

            // Bind click to remove item on the wishlist page
            card.querySelector('.chp-wishlist-remove-page-btn').addEventListener('click', function(e) {
              e.preventDefault();
              if (window.CH_Wishlist) {
                window.CH_Wishlist.toggle(product.handle);
                renderWishlist();
              }
            });
          })
          .catch(err => {
            console.error('Error loading wishlist product details for ' + handle, err);
          })
          .finally(() => {
            loadedProducts++;
            if (loadedProducts === wishlist.length) {
              if (loadingState) loadingState.style.display = 'none';
              if (succeededProducts === 0) {
                if (grid) grid.style.display = 'none';
                if (emptyState) emptyState.style.display = 'block';
              }
            }
          });
      });
    }

    renderWishlist();
  });
</script>

{% schema %}
{
  "name": "Wishlist Page Layout",
  "settings": [],
  "presets": [
    {
      "name": "Wishlist Page Layout"
    }
  ]
}
{% endschema %}
