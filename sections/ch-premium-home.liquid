{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  <!-- 1. Luxury Hero Section -->
  <header class="chp-hero" style="background-image: url({% if section.settings.hero_bg_image != blank %}{{ section.settings.hero_bg_image | image_url: width: 1800 }}{% else %}''{% endif %});">
    <div class="chp-hero-overlay"></div>
    <div class="chp-container" style="position: relative; z-index: 2; width: 100%;">
      <div style="display: grid; grid-template-columns: 1fr; gap: 40px; align-items: center;" class="chp-hero-grid-wrapper">
        <div class="chp-hero-content">
          {%- if section.settings.hero_subheading != blank -%}
            <span class="chp-hero-sub">{{ section.settings.hero_subheading | escape }}</span>
          {%- endif -%}
          {%- if section.settings.hero_heading != blank -%}
            <h1 class="chp-hero-title">{{ section.settings.hero_heading | escape }}</h1>
          {%- endif -%}
          {%- if section.settings.hero_text != blank -%}
            <p class="chp-hero-text">{{ section.settings.hero_text | escape }}</p>
          {%- endif -%}
          
          <div style="display: flex; flex-wrap: wrap; gap: 16px;">
            {%- if section.settings.hero_btn_1_text != blank -%}
              <a href="{{ section.settings.hero_btn_1_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
                {{ section.settings.hero_btn_1_text | escape }}
              </a>
            {%- endif -%}
            {%- if section.settings.hero_btn_2_text != blank -%}
              <a href="{{ section.settings.hero_btn_2_link | default: '#' }}" class="chp-btn chp-btn-outline-white">
                {{ section.settings.hero_btn_2_text | escape }}
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Overlap Image Area -->
        <div class="chp-hero-media-wrapper" style="position: relative; display: flex; justify-content: flex-end;">
          <div class="chp-hero-image-frame" style="position: relative; border: 1px solid rgba(255,255,255,0.2); padding: 12px; background: rgba(255,255,255,0.05); backdrop-filter: blur(5px); max-width: 500px; width: 100%;">
            {%- if section.settings.hero_art_image != blank -%}
              <img src="{{ section.settings.hero_art_image | image_url: width: 800 }}" alt="{{ section.settings.hero_art_image.alt | escape }}" width="{{ section.settings.hero_art_image.width }}" height="{{ section.settings.hero_art_image.height }}" style="width: 100%; height: auto; display: block;" loading="eager" />
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}

            <!-- Navy Overlapping Badge -->
            {%- if section.settings.badge_title != blank or section.settings.badge_text != blank -%}
              <div class="chp-hero-badge" style="position: absolute; bottom: -20px; left: -20px; background-color: var(--ch-navy); color: var(--ch-white); padding: 24px; border: 1px solid var(--ch-border); max-width: 240px; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
                <h4 class="chp-serif" style="font-size: 1.1rem; text-transform: uppercase; margin: 0 0 8px 0; letter-spacing: 0.05em; color: var(--ch-white);">
                  {{ section.settings.badge_title | escape }}
                </h4>
                <p class="chp-sans" style="font-size: 0.8125rem; margin: 0; opacity: 0.8; line-height: 1.4;">
                  {{ section.settings.badge_text | escape }}
                </p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- CSS override for Hero Grid on desktop -->
  <style>
    @media (min-width: 990px) {
      .chp-hero-grid-wrapper {
        grid-template-columns: 6fr 6fr !important;
        gap: 80px !important;
      }
    }
    @media (max-width: 989px) {
      .chp-hero-media-wrapper {
        justify-content: center !important;
        margin-top: 30px;
      }
      .chp-hero-badge {
        position: relative !important;
        bottom: 0 !important;
        left: 0 !important;
        margin-top: 20px;
        max-width: 100% !important;
      }
    }
  </style>

  <!-- 2. About Preview -->
  <section class="chp-section-spacing" style="background-color: var(--ch-cream);">
    <div class="chp-container">
      <div class="chp-editorial-block">
        <div class="chp-editorial-media">
          <div class="chp-editorial-img-wrapper">
            {%- if section.settings.about_image != blank -%}
              <img src="{{ section.settings.about_image | image_url: width: 1000 }}" alt="{{ section.settings.about_image.alt | escape }}" width="{{ section.settings.about_image.width }}" height="{{ section.settings.about_image.height }}" class="chp-editorial-img" loading="lazy" />
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg chp-editorial-img' }}
            {%- endif -%}
          </div>
        </div>

        <div class="chp-editorial-info">
          <span class="chp-section-subtitle">{{ section.settings.about_subtitle | escape }}</span>
          <h2 class="chp-section-title" style="text-align: left;">{{ section.settings.about_title | escape }}</h2>
          <div class="chp-flourish" style="margin: 15px 0 25px 0;">
            <div class="chp-flourish-line"></div>
            <div class="chp-flourish-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 3v18M3 12h18M5 5l14 14M19 5L5 19"/>
              </svg>
            </div>
            <div class="chp-flourish-line"></div>
          </div>
          <p class="chp-section-desc" style="margin-bottom: 30px;">
            {{ section.settings.about_text | escape }}
          </p>
          {%- if section.settings.about_btn_text != blank -%}
            <div>
              <a href="{{ section.settings.about_btn_link | default: '#' }}" class="chp-btn chp-btn-outline-navy">
                {{ section.settings.about_btn_text | escape }}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Tribute Categories -->
  <section class="chp-section-spacing">
    <div class="chp-container">
      <div class="chp-section-header">
        <span class="chp-section-subtitle">{{ section.settings.categories_subtitle | escape }}</span>
        <h2 class="chp-section-title">{{ section.settings.categories_title | escape }}</h2>
        <div class="chp-flourish">
          <div class="chp-flourish-line"></div>
          <div class="chp-flourish-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3l8 8-8 8-8-8z"/>
            </svg>
          </div>
          <div class="chp-flourish-line"></div>
        </div>
        <p class="chp-section-desc">{{ section.settings.categories_desc | escape }}</p>
      </div>

      <div class="chp-category-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="chp-category-card" {{ block.shopify_attributes }}>
              <div class="chp-category-image-wrap">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" class="chp-category-image" loading="lazy" />
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg chp-category-image' }}
                {%- endif -%}
              </div>
              <div class="chp-category-info">
                <h3 class="chp-category-title">{{ block.settings.title | escape }}</h3>
                {%- if block.settings.subtitle != blank -%}
                  <p class="chp-category-meta">{{ block.settings.subtitle | escape }}</p>
                {%- endif -%}
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 4. How It Works -->
  <section class="chp-section-spacing" style="background-color: var(--ch-soft);">
    <div class="chp-container">
      <div class="chp-section-header">
        <span class="chp-section-subtitle">{{ section.settings.steps_subtitle | escape }}</span>
        <h2 class="chp-section-title">{{ section.settings.steps_title | escape }}</h2>
        <div class="chp-flourish">
          <div class="chp-flourish-line"></div>
          <div class="chp-flourish-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
          </div>
          <div class="chp-flourish-line"></div>
        </div>
      </div>

      <div class="chp-steps-grid">
        {%- assign step_index = 1 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="chp-step-card" {{ block.shopify_attributes }}>
              <div class="chp-step-num">0{{ step_index }}</div>
              <h3 class="chp-step-title">{{ block.settings.title | escape }}</h3>
              <p class="chp-step-desc">{{ block.settings.description | escape }}</p>
            </div>
            {%- assign step_index = step_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 5. Gallery Preview -->
  <section class="chp-section-spacing">
    <div class="chp-container">
      <div class="chp-section-header">
        <span class="chp-section-subtitle">{{ section.settings.gallery_subtitle | escape }}</span>
        <h2 class="chp-section-title">{{ section.settings.gallery_title | escape }}</h2>
        <div class="chp-flourish">
          <div class="chp-flourish-line"></div>
          <div class="chp-flourish-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="chp-flourish-line"></div>
        </div>
      </div>

      <div class="chp-gallery-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery' -%}
            <div class="chp-gallery-item" {{ block.shopify_attributes }}>
              <div class="chp-gallery-img-wrap">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" class="chp-gallery-img" loading="lazy" />
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg chp-gallery-img' }}
                {%- endif -%}
              </div>
              <div class="chp-gallery-overlay">
                <h3 class="chp-gallery-title">{{ block.settings.title | escape }}</h3>
                <p class="chp-gallery-meta">{{ block.settings.subtitle | escape }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 6. Pricing/Package Preview -->
  <section class="chp-section-spacing" style="background-color: var(--ch-cream);">
    <div class="chp-container">
      <div class="chp-section-header">
        <span class="chp-section-subtitle">{{ section.settings.pricing_subtitle | escape }}</span>
        <h2 class="chp-section-title">{{ section.settings.pricing_title | escape }}</h2>
        <div class="chp-flourish">
          <div class="chp-flourish-line"></div>
          <div class="chp-flourish-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div class="chp-flourish-line"></div>
        </div>
      </div>

      <div class="chp-pricing-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'package' -%}
            <div class="chp-pricing-card {% if block.settings.featured %}chp-pricing-featured{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.featured -%}
                <div class="chp-pricing-badge">{{ block.settings.badge_text | default: 'Most Popular' | escape }}</div>
              {%- endif -%}
              <h3 class="chp-pricing-title">{{ block.settings.title | escape }}</h3>
              <div class="chp-pricing-price">
                {{ block.settings.price | escape }}
                {%- if block.settings.price_sub != blank -%}
                  <span class="chp-pricing-price-sub">{{ block.settings.price_sub | escape }}</span>
                {%- endif -%}
              </div>

              {%- if block.settings.features != blank -%}
                <ul class="chp-pricing-features">
                  {%- assign feature_lines = block.settings.features | newline_to_br | split: '<br />' -%}
                  {%- for line in feature_lines -%}
                    {%- assign trimmed_line = line | strip -%}
                    {%- if trimmed_line != blank -%}
                      <li class="chp-pricing-feature-item">{{ trimmed_line }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              <div>
                <a href="{{ block.settings.button_link | default: '#' }}" class="chp-btn {% if block.settings.featured %}chp-btn-navy{% else %}chp-btn-outline-navy{% endif %}" style="width: 100%;">
                  {{ block.settings.button_text | default: 'Commission Artwork' | escape }}
                </a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 7. Final Navy CTA Strip -->
  <section class="chp-cta-strip">
    <div class="chp-container">
      {%- if section.settings.cta_heading != blank -%}
        <h2 class="chp-cta-strip-title">{{ section.settings.cta_heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.cta_text != blank -%}
        <p class="chp-cta-strip-text">{{ section.settings.cta_text | escape }}</p>
      {%- endif -%}
      {%- if section.settings.cta_btn_text != blank -%}
        <a href="{{ section.settings.cta_btn_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
          {{ section.settings.cta_btn_text | escape }}
        </a>
      {%- endif -%}
    </div>
  </section>
</div>

