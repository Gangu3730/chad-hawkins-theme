{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  
  <div class="chp-container chp-section-spacing chp-gallery-filter-wrap">
    
    <!-- Header -->
    <div class="chp-section-header chp-reveal">
      <span class="chp-section-sub">{{ section.settings.subheading | escape }}</span>
      <h1 class="chp-section-title chp-serif">{{ section.settings.title | escape }}</h1>
      
      <div class="chp-divider">
        <div class="chp-divider-line"></div>
        <div class="chp-divider-flourish">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="3" fill="none"/>
          </svg>
        </div>
        <div class="chp-divider-line"></div>
      </div>
      
      {%- if section.settings.description != blank -%}
        <p class="chp-section-desc">{{ section.settings.description | escape }}</p>
      {%- endif -%}
    </div>

    <!-- Filter tabs -->
    {%- if section.settings.categories_list != blank -%}
      <div class="chp-filter-tabs chp-reveal">
        <button class="chp-filter-btn is-active" data-filter="all">All Artworks</button>
        {%- assign cats = section.settings.categories_list | split: ',' -%}
        {%- for cat in cats -%}
          {%- assign clean_cat = cat | strip -%}
          {%- if clean_cat != blank -%}
            <button class="chp-filter-btn" data-filter="{{ clean_cat | downcase | replace: ' ', '-' }}">
              {{ clean_cat | escape }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <!-- Editorial grid -->
    <div class="chp-gallery-masonry chp-stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gallery_item' -%}
          {%- assign clean_class = block.settings.category | strip | downcase | replace: ' ', '-' -%}
          <div class="chp-gallery-card chp-stagger-item" data-category="{{ clean_class }}" {{ block.shopify_attributes }}>
            <div class="chp-gallery-card-img-wrap">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 700 }}"
                  alt="{{ block.settings.title | escape }}"
                  class="chp-gallery-card-img"
                  loading="lazy"
                  width="700"
                  height="875"
                />
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'chp-gallery-card-img placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="chp-gallery-card-info">
              <h3 class="chp-gallery-card-title">{{ block.settings.title | escape }}</h3>
              <span class="chp-gallery-card-meta">{{ block.settings.category | escape }}</span>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  <!-- CTA section -->
  {%- if section.settings.show_cta -%}
    <section class="chp-section-spacing chp-navy-cta">
      <div class="chp-container">
        <div class="chp-navy-cta-inner chp-reveal">
          <h2>{{ section.settings.cta_title | escape }}</h2>
          <p>{{ section.settings.cta_text | escape }}</p>
          {%- if section.settings.cta_btn_label != blank and section.settings.cta_btn_link != blank -%}
            <a href="{{ section.settings.cta_btn_link }}" class="chp-btn chp-btn-solid-white">
              {{ section.settings.cta_btn_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Gallery Portfolio",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "PORTFOLIO"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Tribute Art Gallery"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Browse through a curation of custom commissioned portraits and legacy tributes."
    },
    {
      "type": "text",
      "id": "categories_list",
      "label": "Filter Categories (separated by commas)",
      "default": "Memorial, Anniversary, Wedding, Retirement, Family, Achievement"
    },
    {
      "type": "header",
      "content": "CTA Banner"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Strip",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Heading",
      "default": "Ready to commission your custom portrait?"
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Subtext",
      "default": "Let's work together to celebrate your most important stories through fine art."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "Book a Commission"
    },
    {
      "type": "url",
      "id": "cta_btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "gallery_item",
      "name": "Gallery Artwork",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Artwork Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Artwork Title",
          "default": "Custom Pencil Portrait"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category Tag",
          "default": "Memorial"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gallery Portfolio Page"
    }
  ]
}
{% endschema %}
