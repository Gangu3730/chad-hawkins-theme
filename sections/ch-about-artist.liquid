<div class="chp-container section-{{ section.id }}-padding">
  <!-- Page Header -->
  <div class="chp-section-header">
    <span class="chp-section-sub">{{ section.settings.subheading }}</span>
    <h1 class="chp-section-title chp-serif">{{ section.settings.title }}</h1>
    
    <!-- Custom Separator Flourish -->
    <div class="chp-divider">
      <div class="chp-divider-line"></div>
      <div class="chp-divider-flourish">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 3v18M3 12h18M5.636 5.636l12.728 12.728M5.636 19.364L18.364 5.636" stroke-linecap="round"/>
          <circle cx="12" cy="12" r="3" fill="none"/>
        </svg>
      </div>
      <div class="chp-divider-line"></div>
    </div>
  </div>

  <!-- Main Content Grid -->
  <div class="chp-about-main-grid">
    <div class="chp-about-img-col">
      {%- if section.settings.artist_image != blank -%}
        <img 
          src="{{ section.settings.artist_image | image_url: width: 800 }}" 
          alt="{{ section.settings.artist_image.alt | escape }}" 
          class="chp-about-artist-img"
          loading="lazy"
          width="800"
          height="1000"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'chp-about-artist-img placeholder-svg' }}
      {%- endif -%}
    </div>
    
    <div class="chp-about-content-col">
      {%- if section.settings.quote != blank -%}
        <h2 class="chp-about-quote chp-serif">{{ section.settings.quote }}</h2>
      {%- endif -%}
      
      <div class="chp-about-text">
        {{ section.settings.bio_text }}
      </div>
    </div>
  </div>

  <!-- Photo Grid (3 Columns) -->
  <div class="chp-about-photo-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'grid_image' -%}
        {%- if block.settings.image != blank -%}
          <img 
            src="{{ block.settings.image | image_url: width: 500 }}" 
            alt="{{ block.settings.image.alt | escape }}" 
            class="chp-about-photo-item"
            loading="lazy"
            width="500"
            height="280"
            {{ block.shopify_attributes }}
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'chp-about-photo-item placeholder-svg' }}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  <!-- Value Props (4 Columns) -->
  <div class="chp-about-value-props">
    {%- for block in section.blocks -%}
      {%- if block.type == 'value_prop' -%}
        <div class="chp-value-card" {{ block.shopify_attributes }}>
          <div class="chp-value-icon-wrapper">
            {%- case block.settings.icon -%}
              {%- when 'heart' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                </svg>
              {%- when 'pencil' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 20h9M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
                </svg>
              {%- when 'care' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              {%- when 'award' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="7"/>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                </svg>
            {%- endcase -%}
          </div>
          <h3 class="chp-value-title chp-sans">{{ block.settings.title }}</h3>
          <p class="chp-value-desc chp-sans">{{ block.settings.description }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<!-- CTA Banner -->
{%- if section.settings.show_cta -%}
  <div class="chp-cta-banner">
    <div class="chp-container">
      <h2 class="chp-cta-title chp-serif">{{ section.settings.cta_title }}</h2>
      <p class="chp-cta-text chp-sans">{{ section.settings.cta_text }}</p>
      {%- if section.settings.cta_btn_label != blank and section.settings.cta_btn_link != blank -%}
        <a href="{{ section.settings.cta_btn_link }}" class="chp-btn-solid chp-cta-btn chp-sans">
          {{ section.settings.cta_btn_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "About Chad Section",
  "tag": "section",
  "class": "ch-about-artist-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "ABOUT"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "CHAD HAWKINS"
    },
    {
      "type": "image_picker",
      "id": "artist_image",
      "label": "Artist Main Image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / Secondary Heading",
      "default": "Creating meaningful tributes that honor a life and a legacy."
    },
    {
      "type": "richtext",
      "id": "bio_text",
      "label": "Biography Narrative",
      "default": "<p>I'm an artist who believes every life tells a story worth remembering. Through hand-drawn pencil portraits and thoughtfully crafted tribute videos, I help families preserve the people, moments, and memories that matter most.</p><p>Each portrait is drawn by hand with patience, care, and attention to detail. Every line and shade is a tribute to a life lived - a legacy of love, strength, and character that will live on for generations.</p><p>When I'm not in the studio, you'll often find me on the road or on the trail. I'm passionate about running marathons and climbing some of our country's most iconic peaks. These challenges keep me grounded, inspired, and grateful for the gift of time - reminding me to live fully and cherish every moment.</p>"
    },
    {
      "type": "header",
      "content": "CTA Banner Settings"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Heading",
      "default": "LET'S CREATE A TRIBUTE THAT WILL BE REMEMBERED."
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Whether honoring a spouse, parent, grandparent, friend, or loved one, a hand-drawn tribute portrait becomes a lasting reminder of a life that mattered."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "START YOUR TRIBUTE PORTRAIT"
    },
    {
      "type": "url",
      "id": "cta_btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "grid_image",
      "name": "Grid Image (Max 3)",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "value_prop",
      "name": "Value Prop Card (Max 4)",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Type",
          "options": [
            { "value": "heart", "label": "Heart" },
            { "value": "pencil", "label": "Pencil" },
            { "value": "care", "label": "Hand Care" },
            { "value": "award", "label": "Award Badge" }
          ],
          "default": "heart"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "VALUE TITLE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of the value proposition."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Chad Artist",
      "blocks": [
        { "type": "grid_image" },
        { "type": "grid_image" },
        { "type": "grid_image" },
        {
          "type": "value_prop",
          "settings": {
            "icon": "heart",
            "title": "30+ YEARS OF EXPERIENCE",
            "description": "Three decades of dedication to the art of pencil portraiture."
          }
        },
        {
          "type": "value_prop",
          "settings": {
            "icon": "pencil",
            "title": "500+ PORTRAITS CREATED",
            "description": "Hundreds of families have trusted me to create lasting tributes for all occasions."
          }
        },
        {
          "type": "value_prop",
          "settings": {
            "icon": "care",
            "title": "HAND-DRAWN WITH CARE",
            "description": "Each portrait is drawn by hand with patience, care, and attention to detail."
          }
        },
        {
          "type": "value_prop",
          "settings": {
            "icon": "award",
            "title": "ART AND VIDEO TRIBUTES",
            "description": "Masterful artwork combined with impactful tribute videos will be cherished today."
          }
        }
      ]
    }
  ]
}
{% endschema %}
