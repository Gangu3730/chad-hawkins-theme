{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  
  <div class="chp-container chp-section-spacing">
    <!-- Header -->
    <div class="chp-about-hero chp-reveal">
      <span class="chp-section-sub">{{ section.settings.subheading | escape }}</span>
      <h1 class="chp-section-title chp-serif">{{ section.settings.title | escape }}</h1>
      
      <div class="chp-divider">
        <div class="chp-divider-line"></div>
        <div class="chp-divider-flourish">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
            <circle cx="12" cy="12" r="3" fill="none"/>
          </svg>
        </div>
        <div class="chp-divider-line"></div>
      </div>
    </div>

    <!-- Main narrative -->
    <div class="chp-about-story-grid">
      <div class="chp-reveal">
        {%- if section.settings.artist_image != blank -%}
          <div class="chp-about-preview-img-wrap" style="aspect-ratio: 3/4;">
            <img 
              src="{{ section.settings.artist_image | image_url: width: 800 }}" 
              alt="{{ section.settings.artist_image.alt | escape }}" 
              class="chp-about-preview-img"
              loading="lazy"
              width="800"
              height="1066"
            >
          </div>
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'chp-about-preview-img placeholder-svg' }}
        {%- endif -%}
      </div>
      
      <div class="chp-reveal-group">
        {%- if section.settings.quote != blank -%}
          <h2 class="chp-serif chp-stagger-item" style="color: var(--ch-navy); font-size: 1.75rem; margin-bottom: 24px; line-height: 1.3;">
            {{ section.settings.quote | escape }}
          </h2>
        {%- endif -%}
        
        <div class="chp-stagger-item" style="font-size: 1rem; line-height: 1.8; color: var(--ch-text);">
          {{ section.settings.bio_text }}
        </div>
      </div>
    </div>

    <!-- 3 Photo Grid Row -->
    <div class="chp-about-photo-row chp-stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'grid_image' -%}
          <div class="chp-about-photo-item chp-stagger-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img 
                src="{{ block.settings.image | image_url: width: 600 }}" 
                alt="{{ block.settings.image.alt | escape }}" 
                loading="lazy"
                width="600"
                height="600"
                style="width: 100%; height: 100%; object-fit: cover;"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- 4 Stats Card Grid -->
    <div class="chp-stats-grid chp-stagger">
      {%- for block in section.blocks -%}
        {%- if block.type == 'value_prop' -%}
          <div class="chp-stat-card chp-stagger-item" {{ block.shopify_attributes }}>
            <span class="chp-stat-number chp-counter" data-count="{{ block.settings.stat_count | default: '100' }}">
              {{ block.settings.stat_count | default: '100' }}
            </span>
            <span class="chp-stat-label">{{ block.settings.title | escape }}</span>
            <p style="font-size: 0.8125rem; color: var(--ch-muted); margin: 8px 0 0 0; line-height: 1.4;">
              {{ block.settings.description | escape }}
            </p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Navy CTA Strip -->
  {%- if section.settings.show_cta -%}
    <section class="chp-section-spacing chp-navy-cta">
      <div class="chp-container">
        <div class="chp-navy-cta-inner chp-reveal">
          <h2>{{ section.settings.cta_title | escape }}</h2>
          <p>{{ section.settings.cta_text | escape }}</p>
          {%- if section.settings.cta_btn_label != blank and section.settings.cta_btn_link != blank -%}
            <a href="{{ section.settings.cta_btn_link }}" class="chp-btn chp-btn-solid-white">
              {{ section.settings.cta_btn_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "About Chad Section",
  "tag": "section",
  "class": "ch-about-artist-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "ABOUT"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "CHAD HAWKINS"
    },
    {
      "type": "image_picker",
      "id": "artist_image",
      "label": "Artist Main Image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / Secondary Heading",
      "default": "Creating meaningful tributes that honor a life and a legacy."
    },
    {
      "type": "richtext",
      "id": "bio_text",
      "label": "Biography Narrative",
      "default": "<p>I'm an artist who believes every life tells a story worth remembering. Through hand-drawn pencil portraits and thoughtfully crafted tribute videos, I help families preserve the people, moments, and memories that matter most.</p>"
    },
    {
      "type": "header",
      "content": "CTA Banner Settings"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_title",
      "label": "CTA Heading",
      "default": "LET'S CREATE A TRIBUTE THAT WILL BE REMEMBERED."
    },
    {
      "type": "textarea",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Whether honoring a spouse, parent, grandparent, friend, or loved one, a hand-drawn tribute portrait becomes a lasting reminder of a life that mattered."
    },
    {
      "type": "text",
      "id": "cta_btn_label",
      "label": "CTA Button Label",
      "default": "START YOUR TRIBUTE PORTRAIT"
    },
    {
      "type": "url",
      "id": "cta_btn_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "grid_image",
      "name": "Grid Image (Max 3)",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "value_prop",
      "name": "Stat Card (Max 4)",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "stat_count",
          "label": "Stat Number (for counter)",
          "default": "30"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "YEARS OF EXPERIENCE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Three decades of dedication to the art of pencil portraiture."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Chad Artist",
      "blocks": [
        { "type": "grid_image" },
        { "type": "grid_image" },
        { "type": "grid_image" },
        {
          "type": "value_prop",
          "settings": {
            "stat_count": "30",
            "title": "YEARS OF EXPERIENCE",
            "description": "Three decades of dedication to the art of pencil portraiture."
          }
        },
        {
          "type": "value_prop",
          "settings": {
            "stat_count": "500",
            "title": "PORTRAITS CREATED",
            "description": "Hundreds of families have trusted me to create lasting tributes."
          }
        }
      ]
    }
  ]
}
{% endschema %}
