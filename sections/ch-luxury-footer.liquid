{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<footer class="chp-footer">
  <div class="chp-container">
    <div class="chp-footer-grid">
      
      <!-- Brand & signature -->
      <div>
        <h2 class="chp-footer-brand-title">
          {%- if section.settings.logo_svg != blank -%}
            {{ section.settings.logo_svg }}
          {%- elsif section.settings.logo_image != blank -%}
            <img 
              src="{{ section.settings.logo_image | image_url: width: 300 }}" 
              alt="{{ section.settings.logo_image.alt | default: shop.name | escape }}"
              width="150"
              height="40"
              loading="lazy"
              style="max-width: 100%; height: auto;"
            >
          {%- else -%}
            {{ section.settings.brand_title | default: shop.name | escape }}
          {%- endif -%}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="chp-footer-desc">{{ section.settings.description | escape }}</p>
        {%- endif -%}
        {%- if section.settings.signature_image != blank -%}
          <img 
            src="{{ section.settings.signature_image | image_url: width: 280 }}" 
            alt="Chad Hawkins Signature"
            width="140"
            height="50"
            loading="lazy"
            style="display: block; opacity: 0.85;"
          >
        {%- else -%}
          <div class="chp-footer-signature">{{ section.settings.signature_text | escape }}</div>
        {%- endif -%}
      </div>

      <!-- Links menu -->
      <div>
        <h3 class="chp-footer-col-title">{{ section.settings.links_title | escape }}</h3>
        <ul class="chp-footer-links">
          {%- for link in linklists[section.settings.menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- else -%}
            <li><a href="{{ routes.root_url }}">Home</a></li>
            <li><a href="/pages/about-chad">About</a></li>
            <li><a href="/pages/gallery-chad">Gallery</a></li>
            <li><a href="/pages/how-it-works-chad">How It Works</a></li>
            <li><a href="/pages/pricing-chad">Pricing</a></li>
            <li><a href="/pages/contact-chad">Contact</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Secondary Links -->
      <div>
        <h3 class="chp-footer-col-title">SUPPORT</h3>
        <ul class="chp-footer-links">
          <li><a href="/pages/wishlist">My Wishlist</a></li>
          <li><a href="/account">My Account</a></li>
          <li><a href="{{ routes.cart_url }}">View Cart</a></li>
        </ul>
      </div>

      <!-- Action Button / CTA -->
      <div style="display: flex; flex-direction: column; justify-content: flex-start; align-items: flex-start;">
        <h3 class="chp-footer-col-title">COMMISSIONS</h3>
        <p class="chp-footer-desc" style="margin-bottom: 20px;">Interested in discussing a custom drawing layout?</p>
        {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
          <a href="{{ section.settings.btn_link }}" class="chp-btn chp-btn-solid-white" style="font-size: 0.75rem; padding: 12px 24px;">
            {{ section.settings.btn_label | escape }}
          </a>
        {%- endif -%}
      </div>

    </div>

    <!-- Copyright -->
    <div class="chp-footer-bottom">
      <span class="chp-footer-copy">
        {{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' | escape }}
      </span>
      <span class="chp-footer-copy" style="opacity: 0.4;">
        Premium editions style tribute layout
      </span>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer",
  "tag": "section",
  "class": "ch-luxury-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand Title / Logo Text",
      "default": "CHAD HAWKINS TRIBUTES"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Brand Logo Image"
    },
    {
      "type": "html",
      "id": "logo_svg",
      "label": "Brand Logo SVG Code"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Honoring a life and legacy with premium hand-drawn portrait tributes and memorial art."
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature Text fallback",
      "default": "Chad Hawkins"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature Image Upload"
    },
    {
      "type": "text",
      "id": "links_title",
      "label": "Links Block Title",
      "default": "NAVIGATION"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Action Button Label",
      "default": "COMMISSION A PORTRAIT"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Action Button Link"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© [year] Chad Hawkins Tributes. All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "Luxury Footer"
    }
  ]
}
{% endschema %}
