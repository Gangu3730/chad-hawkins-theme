<footer class="chp-footer-wrapper">
  <div class="chp-container">
    <div class="chp-footer-grid">
      
      <!-- Column 1: Brand Logo / Title -->
      <div class="chp-footer-col">
        <h2 class="chp-footer-brand chp-serif">
          {%- if section.settings.logo_svg != blank -%}
            {{ section.settings.logo_svg }}
          {%- elsif section.settings.logo_image != blank -%}
            <img 
              src="{{ section.settings.logo_image | image_url: width: 300 }}" 
              alt="{{ section.settings.logo_image.alt | default: shop.name | escape }}"
              width="150"
              height="40"
              loading="lazy"
            >
          {%- else -%}
            {{ section.settings.brand_title | default: shop.name }}
          {%- endif -%}
        </h2>
      </div>

      <!-- Column 2: Narrative Description & Signature -->
      <div class="chp-footer-col">
        {%- if section.settings.description != blank -%}
          <p class="chp-footer-desc chp-sans">{{ section.settings.description }}</p>
        {%- endif -%}
        
        {%- if section.settings.signature_image != blank -%}
          <img 
            src="{{ section.settings.signature_image | image_url: width: 280 }}" 
            alt="Chad Hawkins Signature"
            class="chp-footer-sig-img"
            width="140"
            height="50"
            loading="lazy"
          >
        {%- else -%}
          <div class="chp-footer-sig-text">{{ section.settings.signature_text }}</div>
        {%- endif -%}
      </div>

      <!-- Column 3: Double-Column Links -->
      <div class="chp-footer-col">
        <h3 class="chp-footer-title chp-sans">{{ section.settings.links_title }}</h3>
        <div class="chp-footer-links-grid">
          {%- for link in linklists[section.settings.menu].links -%}
            <a href="{{ link.url }}" class="chp-footer-link chp-sans">{{ link.title }}</a>
          {%- else -%}
            <!-- Placeholder links if none selected -->
            <a href="/" class="chp-footer-link chp-sans">HOME</a>
            <a href="/pages/about" class="chp-footer-link chp-sans">ABOUT</a>
            <a href="/pages/contact" class="chp-footer-link chp-sans">CONTACT</a>
            <a href="/collections/all" class="chp-footer-link chp-sans">PORTRAITS</a>
          {%- endfor -%}
        </div>
      </div>

      <!-- Column 4: Action Button -->
      <div class="chp-footer-col">
        {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
          <a href="{{ section.settings.btn_link }}" class="chp-footer-btn-box chp-sans">
            {{ section.settings.btn_label }}
          </a>
        {%- endif -%}
      </div>

    </div>

    <!-- Bottom Copyright -->
    <div class="chp-footer-divider-line"></div>
    <div class="chp-footer-copyright-row chp-sans">
      <span>{{ section.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Luxury Footer",
  "tag": "section",
  "class": "ch-luxury-footer-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_title",
      "label": "Brand Title / Logo Text",
      "default": "CHAD HAWKINS TRIBUTES"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Brand Logo Image"
    },
    {
      "type": "html",
      "id": "logo_svg",
      "label": "Brand Logo SVG Code"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Brand Description",
      "default": "Honoring a life and legacy with premium hand-drawn portrait tributes and memorial art."
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature Text fallback",
      "default": "Chad Hawkins"
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature Image Upload"
    },
    {
      "type": "text",
      "id": "links_title",
      "label": "Links Block Title",
      "default": "NAVIGATION"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Action Button Label",
      "default": "COMMISSION A PORTRAIT"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Action Button Link"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "© [year] Chad Hawkins Tributes. All rights reserved."
    }
  ],
  "presets": [
    {
      "name": "Luxury Footer"
    }
  ]
}
{% endschema %}
