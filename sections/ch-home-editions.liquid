{{ 'ch-premium.css' | asset_url | stylesheet_tag }}

<div class="chp chp-wrapper">
  
  <!-- 1. HERO SECTION -->
  <section class="chp-hero-2026">
    <div class="chp-hero-bg">
      {%- if section.settings.hero_bg_image != blank -%}
        <img
          src="{{ section.settings.hero_bg_image | image_url: width: 1920 }}"
          alt="{{ section.settings.hero_bg_image.alt | escape }}"
          width="{{ section.settings.hero_bg_image.width }}"
          height="{{ section.settings.hero_bg_image.height }}"
          class="chp-hero-bg-img"
          loading="eager"
        />
      {%- endif -%}
      <div class="chp-hero-overlay"></div>
    </div>

    <div class="chp-container">
      <div class="chp-hero-inner">
        <div class="chp-hero-content chp-reveal-group">
          {%- if section.settings.hero_subheading != blank -%}
            <div class="chp-hero-eyebrow chp-stagger-item">
              <span class="chp-hero-eyebrow-line"></span>
              <span class="chp-hero-eyebrow-text">{{ section.settings.hero_subheading | escape }}</span>
            </div>
          {%- endif -%}

          {%- if section.settings.hero_heading != blank -%}
            <h1 class="chp-hero-headline chp-text-reveal">{{ section.settings.hero_heading | escape }}</h1>
          {%- endif -%}

          {%- if section.settings.hero_text != blank -%}
            <p class="chp-hero-body chp-stagger-item">{{ section.settings.hero_text | escape }}</p>
          {%- endif -%}

          <div class="chp-hero-actions chp-stagger-item">
            {%- if section.settings.hero_btn_1_text != blank -%}
              <a href="{{ section.settings.hero_btn_1_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
                {{ section.settings.hero_btn_1_text | escape }}
              </a>
            {%- endif -%}
            {%- if section.settings.hero_btn_2_text != blank -%}
              <a href="{{ section.settings.hero_btn_2_link | default: '#' }}" class="chp-btn chp-btn-outline-white">
                {{ section.settings.hero_btn_2_text | escape }}
              </a>
            {%- endif -%}
          </div>
        </div>

        <div class="chp-hero-art-col">
          <div class="chp-hero-art-frame chp-mask-up">
            {%- if section.settings.hero_art_image != blank -%}
              <img
                src="{{ section.settings.hero_art_image | image_url: width: 900 }}"
                alt="{{ section.settings.hero_art_image.alt | escape }}"
                width="{{ section.settings.hero_art_image.width }}"
                height="{{ section.settings.hero_art_image.height }}"
                class="chp-hero-art-img"
                loading="eager"
              />
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'chp-hero-art-img placeholder-svg' }}
            {%- endif -%}

            {%- if section.settings.badge_title != blank or section.settings.badge_text != blank -%}
              <div class="chp-hero-art-badge chp-reveal">
                <h4>{{ section.settings.badge_title | escape }}</h4>
                <p>{{ section.settings.badge_text | escape }}</p>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. STICKY NAV -->
  <nav class="chp-sticky-nav">
    <div class="nav-container">
      <a href="#chp-story" class="is-active">Story</a>
      <a href="#chp-tributes">Tributes</a>
      <a href="#chp-gallery">Gallery</a>
      <a href="#chp-process">Process</a>
      <a href="#chp-pricing">Packages</a>
      <a href="#chp-testimonials">Quote</a>
    </div>
  </nav>

  <!-- 3. ABOUT PREVIEW -->
  <section class="chp-section-spacing" id="chp-story">
    <div class="chp-container">
      <div class="chp-about-preview-grid">
        <div class="chp-about-preview-img-col chp-reveal">
          <div class="chp-about-preview-img-wrap">
            {%- if section.settings.about_image != blank -%}
              <img
                src="{{ section.settings.about_image | image_url: width: 800 }}"
                alt="Chad Hawkins portrait artist"
                class="chp-about-preview-img"
                loading="lazy"
                width="800"
                height="1000"
              />
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'chp-about-preview-img placeholder-svg' }}
            {%- endif -%}
          </div>
        </div>
        
        <div class="chp-about-preview-content chp-reveal-group">
          <span class="chp-section-sub chp-stagger-item">{{ section.settings.about_subtitle | escape }}</span>
          <h2 class="chp-section-title chp-serif chp-stagger-item">{{ section.settings.about_title | escape }}</h2>
          <div class="chp-divider chp-stagger-item">
            <div class="chp-divider-line"></div>
            <div class="chp-divider-flourish">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
                <circle cx="12" cy="12" r="3" fill="none"/>
              </svg>
            </div>
            <div class="chp-divider-line"></div>
          </div>
          <div class="chp-about-preview-text chp-stagger-item">
            {{ section.settings.about_text }}
          </div>
          <div class="chp-stagger-item">
            <a href="{{ section.settings.about_link | default: '#' }}" class="chp-btn chp-btn-navy">
              {{ section.settings.about_btn_text | escape }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. STICKY SCROLLYTELLING -->
  <section class="chp-section-spacing" id="chp-tributes" style="background-color: var(--ch-cream);">
    <div class="chp-container">
      <div class="chp-scrolly">
        <div class="chp-scrolly-left chp-reveal">
          <span class="chp-section-sub">{{ section.settings.scrolly_subheading | escape }}</span>
          <h2 class="chp-section-title chp-serif" style="text-align: left;">{{ section.settings.scrolly_heading | escape }}</h2>
          <p style="color: var(--ch-muted); font-size: 1.0625rem; line-height: 1.7; max-width: 460px;">
            {{ section.settings.scrolly_desc | escape }}
          </p>
          <div class="chp-scrolly-sticky">
            {%- assign card_count = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'scrollytelling_card' -%}
                <div class="chp-scrolly-dot {% if card_count == 0 %}is-active{% endif %}" data-index="{{ card_count }}"></div>
                {%- assign card_count = card_count | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="chp-scrolly-right">
          {%- assign card_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'scrollytelling_card' -%}
              <div class="chp-scrolly-card {% if card_index == 0 %}is-active{% endif %}" data-index="{{ card_index }}" {{ block.shopify_attributes }}>
                <span class="chp-scrolly-card-num">0{{ card_index | plus: 1 }}</span>
                <h3 class="chp-scrolly-card-title">{{ block.settings.title | escape }}</h3>
                <p class="chp-scrolly-card-desc">{{ block.settings.description | escape }}</p>
                {%- if block.settings.image != blank -%}
                  <div class="chp-scrolly-card-img-wrap">
                    <img
                      src="{{ block.settings.image | image_url: width: 600 }}"
                      alt="{{ block.settings.title | escape }}"
                      class="chp-scrolly-card-img"
                      loading="lazy"
                      width="{{ block.settings.image.width | default: 600 }}"
                      height="{{ block.settings.image.height | default: 400 }}"
                    />
                  </div>
                {%- endif -%}
              </div>
              {%- assign card_index = card_index | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </section>

  <!-- 5. GALLERY SHOWCASE -->
  <section class="chp-section-spacing" id="chp-gallery">
    <div class="chp-container">
      <div class="chp-section-header chp-reveal">
        <span class="chp-section-sub">{{ section.settings.gallery_subtitle | escape }}</span>
        <h2 class="chp-section-title chp-serif">{{ section.settings.gallery_title | escape }}</h2>
        <div class="chp-divider">
          <div class="chp-divider-line"></div>
          <div class="chp-divider-flourish">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="3" fill="none"/>
            </svg>
          </div>
          <div class="chp-divider-line"></div>
        </div>
      </div>

      <div class="chp-gallery-masonry chp-stagger">
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery_item' -%}
            <div class="chp-gallery-card chp-stagger-item" {{ block.shopify_attributes }}>
              <div class="chp-gallery-card-img-wrap">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 600 }}"
                    alt="{{ block.settings.title | escape }}"
                    class="chp-gallery-card-img"
                    loading="lazy"
                    width="{{ block.settings.image.width | default: 600 }}"
                    height="{{ block.settings.image.height | default: 750 }}"
                  />
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'chp-gallery-card-img placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="chp-gallery-card-info">
                <h3 class="chp-gallery-card-title">{{ block.settings.title | escape }}</h3>
                <span class="chp-gallery-card-meta">{{ block.settings.category | escape }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div style="text-align: center; margin-top: 50px;" class="chp-reveal">
        <a href="{{ section.settings.gallery_link | default: '#' }}" class="chp-btn chp-btn-outline-navy">
          {{ section.settings.gallery_btn_text | escape }}
        </a>
      </div>
    </div>
  </section>

  <!-- 6. HOW IT WORKS -->
  <section class="chp-section-spacing" id="chp-process" style="background-color: var(--ch-soft);">
    <div class="chp-container">
      <div class="chp-section-header chp-reveal">
        <span class="chp-section-sub">{{ section.settings.process_subtitle | escape }}</span>
        <h2 class="chp-section-title chp-serif">{{ section.settings.process_title | escape }}</h2>
        <div class="chp-divider">
          <div class="chp-divider-line"></div>
          <div class="chp-divider-flourish">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="3" fill="none"/>
            </svg>
          </div>
          <div class="chp-divider-line"></div>
        </div>
      </div>

      <div class="chp-steps-row chp-stagger">
        {%- assign step_index = 1 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'process_step' -%}
            <div class="chp-step-card chp-stagger-item" {{ block.shopify_attributes }}>
              <span class="chp-step-num">0{{ step_index }}</span>
              <div class="chp-step-icon">
                {%- if block.settings.custom_svg != blank -%}
                  {{ block.settings.custom_svg }}
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/>
                  </svg>
                {%- endif -%}
              </div>
              <h3 class="chp-step-title">{{ block.settings.title | escape }}</h3>
              <p class="chp-step-desc">{{ block.settings.description | escape }}</p>
            </div>
            {%- assign step_index = step_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 7. PACKAGES PREVIEW -->
  <section class="chp-section-spacing" id="chp-pricing">
    <div class="chp-container">
      <div class="chp-section-header chp-reveal">
        <span class="chp-section-sub">{{ section.settings.pricing_subtitle | escape }}</span>
        <h2 class="chp-section-title chp-serif">{{ section.settings.pricing_title | escape }}</h2>
        <div class="chp-divider">
          <div class="chp-divider-line"></div>
          <div class="chp-divider-flourish">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 3v18M3 12h18" stroke-linecap="round"/>
              <circle cx="12" cy="12" r="3" fill="none"/>
            </svg>
          </div>
          <div class="chp-divider-line"></div>
        </div>
      </div>

      <div class="chp-packages-grid chp-stagger">
        {%- for block in section.blocks -%}
          {%- if block.type == 'package_card' -%}
            <div class="chp-package-card {% if block.settings.featured %}is-featured{% endif %} chp-stagger-item" {{ block.shopify_attributes }}>
              {%- if block.settings.badge != blank -%}
                <span class="chp-package-badge">{{ block.settings.badge | escape }}</span>
              {%- endif -%}
              <h3 class="chp-package-title">{{ block.settings.title | escape }}</h3>
              <div class="chp-package-price-wrap">
                <span class="chp-package-price">{{ block.settings.price | escape }}</span>
                <span class="chp-package-price-sub">/ One-time fee</span>
              </div>
              <ul class="chp-package-features">
                {%- assign feature_lines = block.settings.features | split: ',' -%}
                {%- for feature in feature_lines -%}
                  <li class="chp-package-feature-item">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    {{ feature | strip | escape }}
                  </li>
                {%- endfor -%}
              </ul>
              <a href="{{ block.settings.btn_link | default: '#' }}" class="chp-btn {% if block.settings.featured %}chp-btn-navy{% else %}chp-btn-outline-navy{% endif %}" style="width: 100%;">
                {{ block.settings.btn_label | escape }}
              </a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  <!-- 8. TESTIMONIAL / EMOTIONAL QUOTE -->
  <section class="chp-section-spacing" id="chp-testimonials" style="background-color: var(--ch-cream);">
    <div class="chp-container">
      <div class="chp-quote-section chp-reveal">
        <p class="chp-quote-text">
          “{{ section.settings.quote_text | escape }}”
        </p>
        <span class="chp-quote-author">— {{ section.settings.quote_author | escape }}</span>
      </div>
    </div>
  </section>

  <!-- 9. FINAL CTA -->
  <section class="chp-section-spacing chp-navy-cta">
    <div class="chp-container">
      <div class="chp-navy-cta-inner chp-reveal">
        <h2>{{ section.settings.cta_heading | escape }}</h2>
        <p>{{ section.settings.cta_text | escape }}</p>
        <a href="{{ section.settings.cta_btn_link | default: '#' }}" class="chp-btn chp-btn-solid-white">
          {{ section.settings.cta_btn_text | escape }}
        </a>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Chad Tributes Home Mega",
  "settings": [
    {
      "type": "header",
      "content": "Hero Settings"
    },
    {
      "type": "image_picker",
      "id": "hero_bg_image",
      "label": "Hero Background Image"
